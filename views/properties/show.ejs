<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<main>
  <section class="property-hero">
    <div class="property-hero-img" style="background-image: url('<%= property.image_url || 'https://images.unsplash.com/photo-1560448204-e02f11c3d0e2?w=1200&q=80' %>')"></div>
  </section>

  <section class="section">
    <div class="container">
      <div class="property-detail">
        <div>
          <div class="property-detail-header">
            <div>
              <h1><%= property.title %></h1>
              <p class="property-location-lg"><%= property.location %></p>
            </div>
            <div class="property-detail-price-box">
              <span class="price-amount">$<%= Number(property.price).toFixed(0) %></span>
              <span class="price-unit">per night</span>
            </div>
          </div>

          <div class="property-stats">
            <div class="stat">
              <span class="stat-value"><%= property.bedrooms %></span>
              <span class="stat-label">Bedrooms</span>
            </div>
            <div class="stat">
              <span class="stat-value"><%= property.bathrooms %></span>
              <span class="stat-label">Bathrooms</span>
            </div>
            <div class="stat">
              <span class="stat-value"><%= property.max_guests %></span>
              <span class="stat-label">Max Guests</span>
            </div>
          </div>

          <div class="property-description">
            <h3>About This Space</h3>
            <p><%= property.description %></p>
          </div>

          <% if (property.amenities && property.amenities.length > 0) { %>
            <div class="property-amenities">
              <h3>Amenities</h3>
              <div class="amenities-list">
                <% property.amenities.forEach(function(amenity) { %>
                  <span class="amenity-tag"><%= amenity %></span>
                <% }) %>
              </div>
            </div>
          <% } %>

          <div class="property-host">
            <h3>Hosted by <%= property.host_name %></h3>
          </div>

          <% if (typeof currentUser !== 'undefined' && currentUser && currentUser.role === 'host' && currentUser.id === property.host_id) { %>
            <div class="property-actions">
              <a href="/properties/<%= property.id %>/edit" class="btn btn-primary">Edit Property</a>
              <form action="/properties/<%= property.id %>?_method=DELETE" method="POST" style="display:inline" onsubmit="return confirm('Delete this property?')">
                <button class="btn btn-danger">Delete</button>
              </form>
            </div>
          <% } %>

          <div class="reviews-section">
            <h3>Reviews (<%= reviews.length %>)</h3>
            <% if (reviews.length === 0) { %>
              <p class="no-reviews">No reviews yet.</p>
            <% } else { %>
              <div class="reviews-list">
                <% reviews.forEach(function(review) { %>
                  <div class="review-card">
                    <div class="review-header">
                      <span class="review-user"><%= review.user_name %></span>
                      <div class="review-rating">
                        <% for (var i = 1; i <= 5; i++) { %>
                          <span class="star <%= i <= review.rating ? 'filled' : '' %>">★</span>
                        <% } %>
                      </div>
                    </div>
                    <p class="review-comment"><%= review.comment %></p>
                    <span class="review-date"><%= new Date(review.created_at).toLocaleDateString() %></span>
                  </div>
                <% }) %>
              </div>
            <% } %>

            <% if (typeof currentUser !== 'undefined' && currentUser && userBookings.length > 0) { %>
              <% var hasReviewed = reviews.find(r => r.user_id === currentUser.id); %>
              <% if (!hasReviewed) { %>
                <div class="review-form-card">
                  <h3>Leave a Review</h3>
                  <form action="/reviews" method="POST">
                    <input type="hidden" name="booking_id" value="<%= userBookings[0].id %>">
                    <input type="hidden" name="property_id" value="<%= property.id %>">
                    <div class="booking-field">
                      <label for="rating">Rating</label>
                      <select name="rating" id="rating" required>
                        <option value="5">★★★★★ (5)</option>
                        <option value="4">★★★★ (4)</option>
                        <option value="3">★★★ (3)</option>
                        <option value="2">★★ (2)</option>
                        <option value="1">★ (1)</option>
                      </select>
                    </div>
                    <div class="booking-field">
                      <label for="comment">Comment</label>
                      <textarea name="comment" id="comment" rows="3" placeholder="Share your experience..." required></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary">Submit Review</button>
                  </form>
                </div>
              <% } %>
            <% } %>
          </div>
        </div>

        <div>
          <div class="booking-card">
            <h3>Book This Stay</h3>
            <% if (typeof currentUser !== 'undefined' && currentUser) { %>
              <% if (isWishlisted) { %>
                <form action="/wishlists/<%= property.id %>?_method=DELETE" method="POST" style="margin-bottom:12px;">
                  <button type="submit" class="btn btn-outline btn-full">♥ Remove from Wishlist</button>
                </form>
              <% } else { %>
                <form action="/wishlists/<%= property.id %>" method="POST" style="margin-bottom:12px;">
                  <button type="submit" class="btn btn-outline btn-full">♡ Save to Wishlist</button>
                </form>
              <% } %>
            <% } %>
            <% if (typeof currentUser !== 'undefined' && currentUser) { %>
              <form action="/bookings" method="POST">
                <input type="hidden" name="property_id" value="<%= property.id %>">
                <div class="booking-field">
                  <label for="check_in">Check In</label>
                  <input type="date" name="check_in" id="check_in" required>
                </div>
                <div class="booking-field">
                  <label for="check_out">Check Out</label>
                  <input type="date" name="check_out" id="check_out" required>
                </div>
                <button type="submit" class="btn btn-primary btn-full">Book Now</button>
              </form>
            <% } else { %>
              <p style="margin-bottom:16px;color:var(--gray-500);font-size:0.9rem;">Login to book this property.</p>
              <a href="/auth/login" class="btn btn-primary btn-full">Login to Book</a>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </section>
</main>

<%- include('../partials/footer') %>
